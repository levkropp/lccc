# Normalize line endings to LF on commit
* text=auto eol=lf

# Source code
*.rs      text eol=lf
*.c       text eol=lf
*.h       text eol=lf
*.py      text eol=lf
*.sh      text eol=lf

# Web / markup
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.toml    text eol=lf
*.json    text eol=lf

# Config
.gitignore      text eol=lf
.gitattributes  text eol=lf
Makefile        text eol=lf

# Binary — never diff or touch line endings
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.pdf    binary
